//@version=6
indicator("Volatility News Stats", overlay=true, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

atrLen = input.int(14, "ATR Length", minval=1)
bbLen  = input.int(20, "BB Length", minval=5)
bbMult = input.float(2.0, "BB Mult", minval=0.5, step=0.5)
hvLen  = input.int(20, "HV Length", minval=5)

// ══════════════════════════════════════════════════════════════════════════════
// VOLATILITY
// ══════════════════════════════════════════════════════════════════════════════

atrVal     = ta.atr(atrLen)
atrPercent = (atrVal / close) * 100
atrSlow    = ta.sma(ta.atr(atrLen), 30)
atrRatio   = atrVal / atrSlow

[bbMid, bbUp, bbLo] = ta.bb(close, bbLen, bbMult)
bbWidth = ((bbUp - bbLo) / bbMid) * 100

logRet  = math.log(close / close[1])
hvDaily = ta.stdev(logRet, hvLen)
hvAnn   = hvDaily * math.sqrt(365) * 100

barsIn5h = math.max(math.round(18000 / timeframe.in_seconds()), 1)
hiN  = ta.highest(high, barsIn5h)
loN  = ta.lowest(low, barsIn5h)
rngPct = ((hiN - loN) / close) * 100

f_pctRank(src, len) =>
    c = 0
    for i = 1 to len
        if src[i] <= src
            c += 1
    (c / len) * 100

rLen = 200
volScore = f_pctRank(atrPercent, rLen) * 0.25 + f_pctRank(atrRatio, rLen) * 0.20 + (100 - f_pctRank(bbWidth, rLen)) * 0.20 + f_pctRank(hvAnn, rLen) * 0.20 + f_pctRank(rngPct, rLen) * 0.15

tfSec   = timeframe.in_seconds()
bars1h  = math.max(math.round(3600 / tfSec), 1)
bars4h  = math.max(math.round(14400 / tfSec), 1)
bars12h = math.max(math.round(43200 / tfSec), 1)
bars24h = math.max(math.round(86400 / tfSec), 1)

// ══════════════════════════════════════════════════════════════════════════════
// ALL EVENTS
// ══════════════════════════════════════════════════════════════════════════════

var array<int>    aDates = array.new_int()
var array<string> aNames = array.new_string()
var array<string> aCats  = array.new_string()

if barstate.isfirst
    // CPI - R
    for m = 1 to 12
        d = m == 1 ? 13 : m == 2 ? 11 : m == 3 ? 11 : m == 4 ? 10 : m == 5 ? 12 : m == 6 ? 10 : m == 7 ? 14 : m == 8 ? 12 : m == 9 ? 11 : m == 10 ? 14 : m == 11 ? 10 : 10
        array.push(aDates, timestamp("UTC", 2026, m, d, 12, 30))
        array.push(aNames, "CPI")
        array.push(aCats, "R")

    // FOMC - R
    array.push(aDates, timestamp("UTC", 2026, 1, 28, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 3, 18, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 4, 29, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 6, 17, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 7, 29, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 9, 16, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 10, 28, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 12, 9, 18, 0))
    array.push(aNames, "FOMC")
    array.push(aCats, "R")

    // NFP - R
    nfpDays = array.from(9, 6, 6, 3, 8, 5, 3, 7, 4, 2, 6, 4)
    for m = 1 to 12
        array.push(aDates, timestamp("UTC", 2026, m, array.get(nfpDays, m - 1), 12, 30))
        array.push(aNames, "NFP")
        array.push(aCats, "R")

    // GDP Advance - R
    array.push(aDates, timestamp("UTC", 2026, 4, 30, 12, 30))
    array.push(aNames, "GDP")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 7, 30, 12, 30))
    array.push(aNames, "GDP")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 10, 29, 12, 30))
    array.push(aNames, "GDP")
    array.push(aCats, "R")

    // ECB - R
    array.push(aDates, timestamp("UTC", 2026, 3, 19, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 6, 11, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 7, 23, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 9, 10, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 10, 29, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 12, 17, 13, 15))
    array.push(aNames, "ECB")
    array.push(aCats, "R")

    // PPI - H
    ppiDays = array.from(14, 12, 12, 14, 13, 11, 15, 13, 10, 15, 13, 15)
    for m = 1 to 12
        array.push(aDates, timestamp("UTC", 2026, m, array.get(ppiDays, m - 1), 12, 30))
        array.push(aNames, "PPI")
        array.push(aCats, "H")

    // Core PCE - H
    pceDays = array.from(29, 0, 13, 9, 28, 25, 30, 26, 30, 29, 25, 23)
    for m = 1 to 12
        dd = array.get(pceDays, m - 1)
        if dd > 0
            array.push(aDates, timestamp("UTC", 2026, m, dd, 12, 30))
            array.push(aNames, "PCE")
            array.push(aCats, "H")

    // ISM Mfg - H
    ismDays = array.from(5, 2, 2, 1, 1, 1, 1, 3, 1, 1, 2, 1)
    for m = 1 to 12
        array.push(aDates, timestamp("UTC", 2026, m, array.get(ismDays, m - 1), 14, 0))
        array.push(aNames, "ISM M")
        array.push(aCats, "H")

    // FOMC Minutes - R
    array.push(aDates, timestamp("UTC", 2026, 2, 18, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 4, 8, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 5, 20, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 7, 8, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 8, 19, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 10, 7, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 11, 18, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")
    array.push(aDates, timestamp("UTC", 2026, 12, 30, 18, 0))
    array.push(aNames, "FMin")
    array.push(aCats, "R")

    // ADP - N
    adpDays = array.from(7, 4, 4, 1, 6, 3, 1, 5, 2, 1, 4, 2)
    for m = 1 to 12
        array.push(aDates, timestamp("UTC", 2026, m, array.get(adpDays, m - 1), 12, 15))
        array.push(aNames, "ADP")
        array.push(aCats, "N")

    // ISM Services - N
    ismSvcDays = array.from(7, 4, 4, 3, 5, 3, 6, 5, 3, 5, 4, 3)
    for m = 1 to 12
        array.push(aDates, timestamp("UTC", 2026, m, array.get(ismSvcDays, m - 1), 14, 0))
        array.push(aNames, "ISM S")
        array.push(aCats, "N")

// ══════════════════════════════════════════════════════════════════════════════
// COLLECT DATA AT EACH EVENT
// ══════════════════════════════════════════════════════════════════════════════

var array<string> resName  = array.new_string()
var array<string> resCat   = array.new_string()
var array<string> resDate  = array.new_string()
var array<float>  resV24   = array.new_float()
var array<float>  resV12   = array.new_float()
var array<float>  resV4    = array.new_float()
var array<float>  resV1    = array.new_float()
var array<float>  resVAt   = array.new_float()
var array<float>  resCloseAt = array.new_float()
var array<float>  resATRpct  = array.new_float()
var array<float>  resBBw     = array.new_float()
var array<int>    resIdx     = array.new_int()

barMs = timeframe.multiplier * 60 * 1000

for i = 0 to array.size(aDates) - 1
    int t = array.get(aDates, i)
    int diff = t - time
    if diff >= 0 and diff < barMs
        array.push(resName, array.get(aNames, i))
        array.push(resCat, array.get(aCats, i))
        array.push(resDate, str.format("{0,date,dd.MM}", t))
        array.push(resV24, volScore[bars24h])
        array.push(resV12, volScore[bars12h])
        array.push(resV4, volScore[bars4h])
        array.push(resV1, volScore[bars1h])
        array.push(resVAt, volScore)
        array.push(resCloseAt, close)
        array.push(resATRpct, atrPercent)
        array.push(resBBw, bbWidth)
        array.push(resIdx, bar_index)

// Capture data 1h AFTER each event
var array<float> resPct1h     = array.new_float()
var array<float> resVol1h     = array.new_float()
var array<float> resATRpct1h  = array.new_float()

if array.size(resIdx) > array.size(resPct1h)
    for j = array.size(resPct1h) to array.size(resIdx) - 1
        array.push(resPct1h, na)
        array.push(resVol1h, na)
        array.push(resATRpct1h, na)

if array.size(resIdx) > 0
    for j = 0 to array.size(resIdx) - 1
        if na(array.get(resPct1h, j))
            int targetBar = array.get(resIdx, j) + bars1h
            if bar_index >= targetBar
                pct = (close - array.get(resCloseAt, j)) / array.get(resCloseAt, j) * 100
                array.set(resPct1h, j, pct)
                array.set(resVol1h, j, volScore)
                array.set(resATRpct1h, j, atrPercent)

// ══════════════════════════════════════════════════════════════════════════════
// SUMMARY AVERAGES
// ══════════════════════════════════════════════════════════════════════════════

var float rSumAt = 0.0
var float rSumBf = 0.0
var int   rCnt = 0
var float hSumAt = 0.0
var float hSumBf = 0.0
var int   hCnt = 0
var float nSumAt = 0.0
var float nSumBf = 0.0
var int   nCnt = 0

if array.size(resName) > (rCnt + hCnt + nCnt)
    idx = rCnt + hCnt + nCnt
    cat = array.get(resCat, idx)
    vAt = array.get(resVAt, idx)
    vBf = array.get(resV24, idx)
    if cat == "R"
        rSumAt += vAt
        rSumBf += vBf
        rCnt += 1
    else if cat == "H"
        hSumAt += vAt
        hSumBf += vBf
        hCnt += 1
    else
        nSumAt += vAt
        nSumBf += vBf
        nCnt += 1

// ══════════════════════════════════════════════════════════════════════════════
// TABLE
// ══════════════════════════════════════════════════════════════════════════════

maxEvents = math.min(array.size(resName), 80)

var table t = table.new(position.top_right, 13, 90, bgcolor=color.new(color.black, 10), border_width=1, border_color=#404040, frame_width=2, frame_color=#606060)

f_vCol(float v) =>
    v > 80 ? #ff0000 : v > 60 ? #ff6600 : v > 40 ? #ffcc00 : v > 20 ? #66cc66 : #00cc00

if barstate.islast and maxEvents > 0
    // ── SUMMARY ──
    table.cell(t, 0, 0, "VOLATILITY NEWS STATS", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(t, 0, 0, 12, 0)

    table.cell(t, 0, 1, "", text_color=#b0b0b0, text_size=size.tiny)
    table.cell(t, 1, 1, "#", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 2, 1, "Avg At", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 3, 1, "Avg 24h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 4, 1, "Delta", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.merge_cells(t, 5, 1, 12, 1)

    // Restriction
    table.cell(t, 0, 2, "Restriction", text_color=color.red, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 2, str.tostring(rCnt), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    rAvg = rCnt > 0 ? rSumAt / rCnt : 0
    rBf  = rCnt > 0 ? rSumBf / rCnt : 0
    table.cell(t, 2, 2, str.tostring(rAvg, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 3, 2, str.tostring(rBf, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    rD = rAvg - rBf
    table.cell(t, 4, 2, (rD >= 0 ? "+" : "") + str.tostring(rD, "#.1"), text_color=rD > 0 ? color.red : color.green, text_size=size.tiny, text_halign=text.align_right)
    table.merge_cells(t, 5, 2, 12, 2)

    // Helicopter
    table.cell(t, 0, 3, "Helicopter", text_color=color.orange, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 3, str.tostring(hCnt), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    hAvg = hCnt > 0 ? hSumAt / hCnt : 0
    hBf  = hCnt > 0 ? hSumBf / hCnt : 0
    table.cell(t, 2, 3, str.tostring(hAvg, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 3, 3, str.tostring(hBf, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    hD = hAvg - hBf
    table.cell(t, 4, 3, (hD >= 0 ? "+" : "") + str.tostring(hD, "#.1"), text_color=hD > 0 ? color.red : color.green, text_size=size.tiny, text_halign=text.align_right)
    table.merge_cells(t, 5, 3, 12, 3)

    // Normal
    table.cell(t, 0, 4, "Normal", text_color=color.yellow, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 4, str.tostring(nCnt), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    nAvg = nCnt > 0 ? nSumAt / nCnt : 0
    nBf  = nCnt > 0 ? nSumBf / nCnt : 0
    table.cell(t, 2, 4, str.tostring(nAvg, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 3, 4, str.tostring(nBf, "#.1"), text_color=color.white, text_size=size.tiny, text_halign=text.align_right)
    nD = nAvg - nBf
    table.cell(t, 4, 4, (nD >= 0 ? "+" : "") + str.tostring(nD, "#.1"), text_color=nD > 0 ? color.red : color.green, text_size=size.tiny, text_halign=text.align_right)
    table.merge_cells(t, 5, 4, 12, 4)

    // ── SEPARATOR ──
    table.cell(t, 0, 5, "", text_color=#606060, text_size=size.tiny)
    table.merge_cells(t, 0, 5, 12, 5)

    // ── PER-EVENT HEADER ──
    table.cell(t, 0, 6, "Event", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 1, 6, "Cat", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_center)
    table.cell(t, 2, 6, "Date", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_center)
    table.cell(t, 3, 6, "-24h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 4, 6, "-12h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 5, 6, "-4h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 6, 6, "-1h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 7, 6, "At", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 8, 6, "ATR%", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 9, 6, "BBw%", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 10, 6, "+1h%", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 11, 6, "ATR%+1h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)
    table.cell(t, 12, 6, "Vol+1h", text_color=#b0b0b0, text_size=size.tiny, text_halign=text.align_right)

    // ── PER-EVENT ROWS ──
    for row = 0 to maxEvents - 1
        r = row + 7
        cat = array.get(resCat, row)
        catCol = cat == "R" ? color.red : cat == "H" ? color.orange : color.yellow

        table.cell(t, 0, r, array.get(resName, row), text_color=catCol, text_size=size.tiny, text_halign=text.align_left)
        table.cell(t, 1, r, cat, text_color=catCol, text_size=size.tiny, text_halign=text.align_center)
        table.cell(t, 2, r, array.get(resDate, row), text_color=color.white, text_size=size.tiny, text_halign=text.align_center)

        v24 = array.get(resV24, row)
        v12 = array.get(resV12, row)
        v4  = array.get(resV4, row)
        v1  = array.get(resV1, row)
        vAt = array.get(resVAt, row)

        table.cell(t, 3, r, str.tostring(v24, "#.0"), text_color=f_vCol(v24), text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 4, r, str.tostring(v12, "#.0"), text_color=f_vCol(v12), text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 5, r, str.tostring(v4, "#.0"), text_color=f_vCol(v4), text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 6, r, str.tostring(v1, "#.0"), text_color=f_vCol(v1), text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 7, r, str.tostring(vAt, "#.0"), text_color=f_vCol(vAt), text_size=size.tiny, text_halign=text.align_right)

        // ATR% and BB Width at event
        atrP = array.get(resATRpct, row)
        bbW  = array.get(resBBw, row)
        table.cell(t, 8, r, str.tostring(atrP, "#.##"), text_color=atrP > 1.0 ? color.red : atrP > 0.5 ? #ffcc00 : color.green, text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 9, r, str.tostring(bbW, "#.##"), text_color=bbW > 2.0 ? color.red : bbW > 1.0 ? #ffcc00 : color.green, text_size=size.tiny, text_halign=text.align_right)

        // +1h price change, ATR% after, vol after
        pctText = "..."
        pctCol  = #606060
        atrAText = "..."
        atrACol  = #606060
        volAText = "..."
        volACol  = #606060
        hasAfter = row < array.size(resPct1h) and not na(array.get(resPct1h, row))
        if hasAfter
            pct = array.get(resPct1h, row)
            pctText := (pct >= 0 ? "+" : "") + str.tostring(pct, "#.##") + "%"
            pctCol := pct >= 0 ? color.green : color.red
            atrAVal = array.get(resATRpct1h, row)
            atrAText := str.tostring(atrAVal, "#.##")
            atrACol := atrAVal > atrP ? color.red : color.green
            volAVal = array.get(resVol1h, row)
            volAText := str.tostring(volAVal, "#.0")
            volACol := f_vCol(volAVal)
        table.cell(t, 10, r, pctText, text_color=pctCol, text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 11, r, atrAText, text_color=atrACol, text_size=size.tiny, text_halign=text.align_right)
        table.cell(t, 12, r, volAText, text_color=volACol, text_size=size.tiny, text_halign=text.align_right)

    // Summary row
    sr = maxEvents + 7
    table.cell(t, 0, sr, "TOTAL: " + str.tostring(maxEvents), text_color=color.aqua, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(t, 0, sr, 12, sr)
