// ══════════════════════════════════════════════════════════════════════════════
// EVENT DETECTION ENGINE
// ══════════════════════════════════════════════════════════════════════════════

msBeforeAlert = hoursBeforeAlert * 3600 * 1000

f_findEvent(array<int> dates, array<string> names) =>
    string foundName = ""
    bool isEvent = false
    bool isPreEvent = false
    for i = 0 to array.size(dates) - 1
        int t = array.get(dates, i)
        int diff = t - time
        if diff >= 0 and diff < msBeforeAlert
            isPreEvent := true
            foundName := array.get(names, i)
            break
        if diff >= -timeframe.multiplier * 60 * 1000 and diff < timeframe.multiplier * 60 * 1000
            isEvent := true
            foundName := array.get(names, i)
            break
    [isEvent, isPreEvent, foundName]

[rEvent, rPre, rName] = f_findEvent(rDates, rNames)
[hEvent, hPre, hName] = f_findEvent(hDates, hNames)
[nEvent, nPre, nName] = f_findEvent(nDates, nNames)

isRestriction = showRestriction and rEvent
isHelicopter  = showHelicopter and hEvent
isNormal      = showNormal and nEvent
eventDetected = isRestriction or isHelicopter or isNormal

preRestriction = showRestriction and rPre
preHelicopter  = showHelicopter and hPre
preNormal      = showNormal and nPre
isPreNews = preRestriction or preHelicopter or preNormal

currentEvent = rEvent ? rName : hEvent ? hName : nEvent ? nName : ""
preEventName = rPre ? rName : hPre ? hName : nPre ? nName : ""
preNewsCategory = preRestriction ? "Restriction" : preHelicopter ? "Helicopter" : preNormal ? "Normal" : ""

preNewsColor = preRestriction ? color.new(color.red, 85) : preHelicopter ? color.new(color.orange, 85) : preNormal ? color.new(color.yellow, 88) : na

// ══════════════════════════════════════════════════════════════════════════════
// HISTORICAL STATS — collect volScore at each event and N hours before
// ══════════════════════════════════════════════════════════════════════════════

var float rVolSum = 0.0
var float rVolBeforeSum = 0.0
var int   rCount = 0
var float rVolMax = 0.0
var float rVolMin = 100.0

var float hVolSum = 0.0
var float hVolBeforeSum = 0.0
var int   hCount = 0

var float nVolSum = 0.0
var float nVolBeforeSum = 0.0
var int   nCount = 0

var float allMoveSum = 0.0
var float rMoveSum = 0.0
var float hMoveSum = 0.0
var float nMoveSum = 0.0

volBefore = volScore[barsIn4h > 0 ? barsIn4h : 1]

if rEvent and not rEvent[1]
    rVolSum += volScore
    rVolBeforeSum += volBefore
    rCount += 1
    rMoveSum += math.abs(volScore - volBefore)
    if volScore > rVolMax
        rVolMax := volScore
    if volScore < rVolMin
        rVolMin := volScore

if hEvent and not hEvent[1]
    hVolSum += volScore
    hVolBeforeSum += volBefore
    hCount += 1
    hMoveSum += math.abs(volScore - volBefore)

if nEvent and not nEvent[1]
    nVolSum += volScore
    nVolBeforeSum += volBefore
    nCount += 1
    nMoveSum += math.abs(volScore - volBefore)

rAvgVol = rCount > 0 ? rVolSum / rCount : na
rAvgBefore = rCount > 0 ? rVolBeforeSum / rCount : na
rAvgMove = rCount > 0 ? rMoveSum / rCount : na

hAvgVol = hCount > 0 ? hVolSum / hCount : na
hAvgBefore = hCount > 0 ? hVolBeforeSum / hCount : na
hAvgMove = hCount > 0 ? hMoveSum / hCount : na

nAvgVol = nCount > 0 ? nVolSum / nCount : na
nAvgBefore = nCount > 0 ? nVolBeforeSum / nCount : na
nAvgMove = nCount > 0 ? nMoveSum / nCount : na

// ══════════════════════════════════════════════════════════════════════════════
// VISUAL: CHART
// ══════════════════════════════════════════════════════════════════════════════

bgcolor(showBgZone and isPreNews ? preNewsColor : na, title="Pre-News Zone")

plotshape(isRestriction, title="Restriction", style=shape.diamond, location=location.abovebar, color=color.red, size=size.normal, text="R")
plotshape(isHelicopter, title="Helicopter", style=shape.diamond, location=location.abovebar, color=color.orange, size=size.normal, text="H")
plotshape(isNormal, title="Normal", style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.normal, text="N")

// ══════════════════════════════════════════════════════════════════════════════
// VOLATILITY TABLE
// ══════════════════════════════════════════════════════════════════════════════

var tblPos = tablePos == "Top Left" ? position.top_left : tablePos == "Top Right" ? position.top_right : tablePos == "Bottom Left" ? position.bottom_left : position.bottom_right

var table volTable = table.new(tblPos, 3, 16, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.gray, frame_width=2, frame_color=color.gray)

f_scoreColor(float score) =>
    score > 70 ? color.red : score > 40 ? color.orange : color.green

f_deltaColor(float d) =>
    d > 5 ? color.red : d < -5 ? color.green : #b0b0b0

f_deltaStr(float d) =>
    (d >= 0 ? "+" : "") + str.tostring(d, "#.0")

if showTable and barstate.islast
    table.cell(volTable, 0, 0, "VOLATILITY DASHBOARD", text_color=color.white, text_size=size.normal, bgcolor=color.new(#1a1a2e, 0), text_halign=text.align_left)
    table.merge_cells(volTable, 0, 0, 2, 0)

    table.cell(volTable, 0, 1, "Overall Score", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 1, str.tostring(volScore, "#.0") + " / 100", text_color=volColor, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 1, volState, text_color=volColor, text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 2, "------------------------", text_color=#909090, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(volTable, 0, 2, 2, 2)

    table.cell(volTable, 0, 3, "ATR(" + str.tostring(atrLen) + ")", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 3, str.tostring(atrVal, "#.1") + " (" + str.tostring(atrPercent, "#.##") + "%)", text_color=color.white, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 3, str.tostring(atrScore, "#.0"), text_color=f_scoreColor(atrScore), text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 4, "ATR Ratio", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    atrRatioColor = atrRatio > 1.2 ? color.red : atrRatio < 0.8 ? color.green : color.white
    table.cell(volTable, 1, 4, str.tostring(atrRatio, "#.##") + "x", text_color=atrRatioColor, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 4, str.tostring(ratioScore, "#.0"), text_color=f_scoreColor(ratioScore), text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 5, "BB Width", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    sqzText = bbSqueeze ? " SQUEEZE" : ""
    table.cell(volTable, 1, 5, str.tostring(bbWidth, "#.##") + "%" + sqzText, text_color=bbSqueeze ? color.fuchsia : color.white, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 5, str.tostring(bbScore, "#.0"), text_color=f_scoreColor(bbScore), text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 6, "Hist. Vol", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 6, str.tostring(hvAnnual, "#.#") + "% ann.", text_color=color.white, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 6, str.tostring(hvScore, "#.0"), text_color=f_scoreColor(hvScore), text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 7, "Range " + str.tostring(hoursBeforeAlert) + "h", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 7, str.tostring(rangePercent, "#.##") + "%", text_color=color.white, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 7, str.tostring(rangeScore, "#.0"), text_color=f_scoreColor(rangeScore), text_size=size.small, text_halign=text.align_right)

    // Volatility change section
    table.cell(volTable, 0, 8, "------------------------", text_color=#909090, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(volTable, 0, 8, 2, 8)

    table.cell(volTable, 0, 9, "Vol Change", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 9, "Delta", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 9, "Was", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 10, "4h ago", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 10, f_deltaStr(delta4h), text_color=f_deltaColor(delta4h), text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 10, str.tostring(vol4hAgo, "#.0"), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 11, "12h ago", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 11, f_deltaStr(delta12h), text_color=f_deltaColor(delta12h), text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 11, str.tostring(vol12hAgo, "#.0"), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    table.cell(volTable, 0, 12, "24h ago", text_color=#b0b0b0, text_size=size.small, text_halign=text.align_left)
    table.cell(volTable, 1, 12, f_deltaStr(delta24h), text_color=f_deltaColor(delta24h), text_size=size.small, text_halign=text.align_right)
    table.cell(volTable, 2, 12, str.tostring(vol24hAgo, "#.0"), text_color=color.white, text_size=size.small, text_halign=text.align_right)

    // News section
    table.cell(volTable, 0, 13, "------------------------", text_color=#909090, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(volTable, 0, 13, 2, 13)

    newsText = ""
    newsColor = #909090
    if isPreNews
        newsText := "PRE-NEWS: " + preEventName + " (" + preNewsCategory + ")"
        newsColor := preRestriction ? color.red : preHelicopter ? color.orange : color.yellow
    else if eventDetected
        newsText := "EVENT NOW: " + currentEvent
        newsColor := color.fuchsia
    else
        newsText := "No active event"
        newsColor := #909090
    table.cell(volTable, 0, 14, newsText, text_color=newsColor, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(volTable, 0, 14, 2, 14)

    // Next event countdown
    nextName = ""
    nextMs = 999999999999
    for i = 0 to array.size(rDates) - 1
        int d = array.get(rDates, i) - time
        if d > 0 and d < nextMs
            nextMs := d
            nextName := array.get(rNames, i) + " [R]"
    for i = 0 to array.size(hDates) - 1
        int d = array.get(hDates, i) - time
        if d > 0 and d < nextMs
            nextMs := d
            nextName := array.get(hNames, i) + " [H]"
    for i = 0 to array.size(nDates) - 1
        int d = array.get(nDates, i) - time
        if d > 0 and d < nextMs
            nextMs := d
            nextName := array.get(nNames, i) + " [N]"
    hoursLeft = nextMs / 3600000.0
    daysLeft = hoursLeft / 24.0
    countdownText = nextName != "" ? "Next: " + nextName + " in " + (daysLeft > 1 ? str.tostring(daysLeft, "#.0") + "d" : str.tostring(hoursLeft, "#.0") + "h") : ""
    table.cell(volTable, 0, 15, countdownText, text_color=color.aqua, text_size=size.tiny, text_halign=text.align_left)
    table.merge_cells(volTable, 0, 15, 2, 15)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(isPreNews and not isPreNews[1], title="Pre-News Zone Started", message="Pre-news zone started on {{ticker}}")
alertcondition(isPreNews and preRestriction and volScore < 30, title="Low Vol + Restriction", message="Low vol squeeze before Restriction event on {{ticker}}")
alertcondition(isPreNews and volScore > 70, title="High Vol Pre-News", message="High volatility before news on {{ticker}}")
alertcondition(isPreNews and bbSqueeze, title="BB Squeeze Pre-News", message="BB squeeze before news on {{ticker}}")
alertcondition(eventDetected and not eventDetected[1], title="News Event Now", message="News event detected on {{ticker}}")
