//@version=6
indicator("Volatility Before News", overlay=true, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grpVol  = "Volatility Settings"
atrLen  = input.int(14, "ATR Length", minval=1, group=grpVol)
atrAvgLen = input.int(30, "ATR Average Period (days)", minval=5, group=grpVol)
bbLen   = input.int(20, "Bollinger Band Length", minval=5, group=grpVol)
bbMult  = input.float(2.0, "BB Multiplier", minval=0.5, step=0.5, group=grpVol)
hvLen   = input.int(20, "Historical Volatility Length", minval=5, group=grpVol)

grpNews = "News Settings"
showRestriction = input.bool(true, "Show Restriction (Red)", group=grpNews)
showHelicopter  = input.bool(true, "Show Helicopter (Orange)", group=grpNews)
showNormal      = input.bool(true, "Show Normal (Yellow)", group=grpNews)
hoursBeforeAlert = input.int(5, "Hours before event for alert zone", minval=1, maxval=24, group=grpNews)

grpDisplay = "Display"
tablePos    = input.string("Top Right", "Table Position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group=grpDisplay)
showBgZone  = input.bool(true, "Highlight pre-news zone on chart", group=grpDisplay)
showTable   = input.bool(true, "Show Volatility Table", group=grpDisplay)

// ══════════════════════════════════════════════════════════════════════════════
// VOLATILITY CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════

atrVal      = ta.atr(atrLen)
atrPercent  = (atrVal / close) * 100
atrSlow     = ta.sma(ta.atr(atrLen), atrAvgLen)
atrRatio    = atrVal / atrSlow

[bbMiddle, bbUpper, bbLower] = ta.bb(close, bbLen, bbMult)
bbWidth     = ((bbUpper - bbLower) / bbMiddle) * 100
bbWidthAvg  = ta.sma(bbWidth, atrAvgLen)
bbSqueeze   = bbWidth < bbWidthAvg * 0.75

logReturn   = math.log(close / close[1])
hvDaily     = ta.stdev(logReturn, hvLen)
hvAnnual    = hvDaily * math.sqrt(365) * 100

barsInHours = math.max(math.round(hoursBeforeAlert * 3600 / timeframe.in_seconds()), 1)
highestN    = ta.highest(high, barsInHours > 0 ? barsInHours : 1)
lowestN     = ta.lowest(low, barsInHours > 0 ? barsInHours : 1)
rangePercent = ((highestN - lowestN) / close) * 100

// ══════════════════════════════════════════════════════════════════════════════
// VOLATILITY SCORING (0-100)
// ══════════════════════════════════════════════════════════════════════════════

f_percentRank(src, len) =>
    count = 0
    for i = 1 to len
        if src[i] <= src
            count += 1
    (count / len) * 100

rankLen = 200
atrScore    = f_percentRank(atrPercent, rankLen)
ratioScore  = f_percentRank(atrRatio, rankLen)
bbScore     = 100 - f_percentRank(bbWidth, rankLen)
hvScore     = f_percentRank(hvAnnual, rankLen)
rangeScore  = f_percentRank(rangePercent, rankLen)

volScore = (atrScore * 0.25 + ratioScore * 0.20 + bbScore * 0.20 + hvScore * 0.20 + rangeScore * 0.15)
volState = volScore > 70 ? "HIGH" : volScore > 40 ? "MEDIUM" : "LOW"
volColor = volScore > 70 ? color.red : volScore > 40 ? color.orange : color.green

// Volatility deltas (how volScore changed over time)
barsIn4h  = math.max(math.round(14400 / timeframe.in_seconds()), 1)
barsIn12h = math.max(math.round(43200 / timeframe.in_seconds()), 1)
barsIn24h = math.max(math.round(86400 / timeframe.in_seconds()), 1)
vol4hAgo  = volScore[barsIn4h > 0 ? barsIn4h : 1]
vol12hAgo = volScore[barsIn12h > 0 ? barsIn12h : 1]
vol24hAgo = volScore[barsIn24h > 0 ? barsIn24h : 1]
delta4h   = volScore - vol4hAgo
delta12h  = volScore - vol12hAgo
delta24h  = volScore - vol24hAgo

